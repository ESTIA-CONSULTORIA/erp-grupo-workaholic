// ─────────────────────────────────────────────────────────────
//  PRISMA SCHEMA — ERP GRUPO WORKAHOLIC
//  DB: PostgreSQL (Supabase)
//  Principio: lógica por IDs/metadatos, nunca por títulos
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ══════════════════════════════════════════════════════════════
//  AUTENTICACIÓN Y USUARIOS
// ══════════════════════════════════════════════════════════════

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyRoles    UserCompanyRole[]
  branchRoles     UserBranchRole[]
  cutsCreated     Cut[]             @relation("CutCreatedBy")
  cutsApproved    Cut[]             @relation("CutApprovedBy")
  expenses        Expense[]
  purchases       Purchase[]
  documentUploads DocumentUpload[]
  auditLogs       AuditLog[]
  documents       Document[]
  pin             String?
  cortesCajero    CorteCaja[] @relation("CorteCajaCajero")
  cortesValidador CorteCaja[] @relation("CorteCajaValidador")
  employee        Employee?   @relation("UserEmployee")
  @@map("users")
}

model Role {
  id          String @id @default(cuid())
  code        String @unique
  name        String
  description String

  permissions  RolePermission[]
  companyRoles UserCompanyRole[]
  branchRoles  UserBranchRole[]

  @@map("roles")
}

// ══════════════════════════════════════════════════════════════
//  PERMISOS (Sistema Legacy - por código)
// ══════════════════════════════════════════════════════════════

model Permission {
  id   String @id @default(cuid())
  code String @unique
  name String

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId],       references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ══════════════════════════════════════════════════════════════
//  NUEVO SISTEMA DE PERMISOS POR MÓDULO Y ACCIÓN
// ══════════════════════════════════════════════════════════════

model RoleModulePermission {
  id          String  @id @default(cuid())
  roleCode    String
  module      String
  action      String
  allowed     Boolean @default(true)
  companyId   String?
  createdAt   DateTime @default(now())

  @@unique([roleCode, module, action, companyId])
  @@map("role_module_permissions")
}

// Usuario puede tener rol en múltiples empresas
model UserCompanyRole {
  id        String  @id @default(cuid())
  userId    String
  companyId String
  roleId    String
  user      User    @relation(fields: [userId],    references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role    @relation(fields: [roleId],    references: [id])

  @@unique([userId, companyId])
  @@map("user_company_roles")
}

// Capturistas asignados a sucursales específicas
model UserBranchRole {
  id       String @id @default(cuid())
  userId   String
  branchId String
  roleId   String
  user     User   @relation(fields: [userId],   references: [id], onDelete: Cascade)
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  role     Role   @relation(fields: [roleId],   references: [id])

  @@unique([userId, branchId])
  @@map("user_branch_roles")
}

// ══════════════════════════════════════════════════════════════
//  EMPRESAS Y SUCURSALES
// ══════════════════════════════════════════════════════════════

model Company {
  id            String  @id @default(cuid())
  code          String  @unique
  name          String
  color         String  @default("#3b82f6")
  logoUrl       String?
  hasAB         Boolean @default(true)
  hasProduction Boolean @default(false)
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branches         Branch[]
  userRoles        UserCompanyRole[]
  financialSchema  FinancialSchema?
  cashAccounts     CashAccount[]
  clients          Client[]
  suppliers        Supplier[]
  cuts             Cut[]
  expenses         Expense[]
  purchases        Purchase[]
  receivables      Receivable[]
  payables         Payable[]
  flowMovements    FlowMovement[]
  periodClosures   PeriodClosure[]
  documentUploads  DocumentUpload[]
  products         Product[]
  recipes          Recipe[]
  productionBatches ProductionBatch[]
  cxcs             CxC[]
  documents        Document[]
  employees        Employee[]
  hrConfig         CompanyHRConfig?
  payrollPeriods   PayrollPeriod[]
  insumos          Insumo[]
  ordenesCompra    OrdenCompra[]
  cortesCaja       CorteCaja[]
  lotesProduccion  LoteProduccion[]
  transfersFrom    IntercompanyTransfer[] @relation("TransferFrom")
  transfersTo      IntercompanyTransfer[] @relation("TransferTo")

  // Palestra
  serviceCatalog   ServiceCatalog[]
  membershipTypes  MembershipType[]
  memberships      Membership[]
  coachCommissions CoachCommission[]
  palestraProducts PalestraProduct[]

  @@map("companies")
}

model Branch {
  id        String  @id @default(cuid())
  companyId String
  code      String
  name      String
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userRoles   UserBranchRole[]
  cuts        Cut[]
  cashCounts  CashCount[]
  flowMovements FlowMovement[]
  employees   Employee[]

  @@unique([companyId, code])
  @@map("branches")
}

// ══════════════════════════════════════════════════════════════
//  ESQUEMA FINANCIERO POR EMPRESA (configurable)
// ══════════════════════════════════════════════════════════════

model FinancialSchema {
  id        String  @id @default(cuid())
  companyId String  @unique
  name      String
  version   Int     @default(1)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sections FinancialSection[]

  @@map("financial_schemas")
}

model FinancialSection {
  id            String  @id @default(cuid())
  schemaId      String
  code          String
  name          String
  order         Int
  isVisible     Boolean @default(true)
  affectsResult Boolean @default(true)

  schema FinancialSchema  @relation(fields: [schemaId], references: [id], onDelete: Cascade)
  groups FinancialGroup[]

  @@unique([schemaId, code])
  @@map("financial_sections")
}

model FinancialGroup {
  id        String  @id @default(cuid())
  sectionId String
  code      String
  name      String
  order     Int
  isSummary Boolean @default(false)

  section FinancialSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  rubrics FinancialRubric[]

  @@unique([sectionId, code])
  @@map("financial_groups")
}

model FinancialRubric {
  id      String @id @default(cuid())
  groupId String
  code    String
  name    String
  order   Int

  rubricType        String
  allowsContado     Boolean @default(false)
  allowsCxC         Boolean @default(false)
  allowsDiscount    Boolean @default(false)
  allowsCourtesy    Boolean @default(false)
  requiresClient    Boolean @default(false)
  requiresSupplier  Boolean @default(false)
  requiresBank      Boolean @default(false)
  requiresTerminal  Boolean @default(false)
  affectsGrossSale  Boolean @default(false)
  affectsNetSale    Boolean @default(false)
  affectsFlow       Boolean @default(false)
  affectsCxC        Boolean @default(false)
  affectsCxP        Boolean @default(false)
  affectsCost       Boolean @default(false)
  affectsExpense    Boolean @default(false)
  affectsResult     Boolean @default(true)
  affectsExternalOp Boolean @default(false)
  showInSummary     Boolean @default(true)
  showInStatement   Boolean @default(true)
  showInDashboard   Boolean @default(true)
  isActive          Boolean @default(true)

  group    FinancialGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  cutLines CutLine[]
  expenses Expense[]
  purchases Purchase[]

  @@unique([groupId, code])
  @@map("financial_rubrics")
}

// ══════════════════════════════════════════════════════════════
//  CATÁLOGOS MAESTROS
// ══════════════════════════════════════════════════════════════

model Client {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  email       String?
  phone       String?
  rfc         String?
  address     String?
  creditLimit Decimal  @default(0) @db.Decimal(12,2)
  creditDays  Int      @default(30)
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cutLines    CutLine[]
  receivables Receivable[]
  cxcs        CxC[]
  ordenesCompra OrdenCompra[]
  sales       Sale[]

  @@map("clients")
}

model Supplier {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses  Expense[]
  purchases Purchase[]
  payables  Payable[]

  @@map("suppliers")
}

model CashAccount {
  id            String  @id @default(cuid())
  companyId     String
  code          String
  name          String
  type          String
  currency      String  @default("MXN")
  bankName      String?
  accountNumber String?
  isActive      Boolean @default(true)

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cutLines      CutLine[]
  flowMovements FlowMovement[]
  cashCounts    CashCount[]
  expenses      Expense[]
  cxcPayments   CxCPayment[]

  @@unique([companyId, code])
  @@map("cash_accounts")
}

// ══════════════════════════════════════════════════════════════
//  CORTES
// ══════════════════════════════════════════════════════════════

model Cut {
  id           String   @id @default(cuid())
  companyId    String
  branchId     String
  folio        String
  date         DateTime @db.Date
  shift        String?
  status       String   @default("BORRADOR")
  notes        String?
  createdById  String
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company   @relation(fields: [companyId], references: [id])
  branch     Branch    @relation(fields: [branchId],  references: [id])
  createdBy  User      @relation("CutCreatedBy",  fields: [createdById],  references: [id])
  approvedBy User?     @relation("CutApprovedBy", fields: [approvedById], references: [id])
  lines      CutLine[]

  @@unique([companyId, folio])
  @@map("cuts")
}

model CutLine {
  id            String  @id @default(cuid())
  cutId         String
  rubricId      String
  clientId      String?
  cashAccountId String?

  paymentType   String
  currency      String  @default("MXN")
  exchangeRate  Decimal @default(1) @db.Decimal(10,4)

  grossAmount   Decimal @db.Decimal(12,2)
  discount      Decimal @default(0) @db.Decimal(12,2)
  courtesy      Decimal @default(0) @db.Decimal(12,2)
  netAmount     Decimal @db.Decimal(12,2)

  reference     String?
  notes         String?

  cut         Cut            @relation(fields: [cutId],         references: [id], onDelete: Cascade)
  rubric      FinancialRubric @relation(fields: [rubricId],     references: [id])
  client      Client?         @relation(fields: [clientId],     references: [id])
  cashAccount CashAccount?    @relation(fields: [cashAccountId],references: [id])

  @@map("cut_lines")
}

// ══════════════════════════════════════════════════════════════
//  FLUJO DE EFECTIVO Y ARQUEOS
// ══════════════════════════════════════════════════════════════

model FlowMovement {
  id            String   @id @default(cuid())
  companyId     String
  branchId      String
  cashAccountId String
  date          DateTime @db.Date
  type          String
  originType    String
  originId      String?
  rubricId      String?
  amount        Decimal  @db.Decimal(12,2)
  currency      String   @default("MXN")
  exchangeRate  Decimal  @default(1) @db.Decimal(10,4)
  amountMxn     Decimal  @db.Decimal(12,2)
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())

  company     Company     @relation(fields: [companyId],     references: [id])
  branch      Branch      @relation(fields: [branchId],      references: [id])
  cashAccount CashAccount @relation(fields: [cashAccountId], references: [id])

  @@map("flow_movements")
}

model CashCount {
  id                String   @id @default(cuid())
  companyId         String
  branchId          String
  cashAccountId     String
  date              DateTime @db.Date
  periodId          String?

  openingBalance    Decimal @db.Decimal(12,2)
  inflows           Decimal @db.Decimal(12,2)
  outflows          Decimal @db.Decimal(12,2)
  theoreticalBalance Decimal @db.Decimal(12,2)
  physicalCount     Decimal @db.Decimal(12,2)
  difference        Decimal @db.Decimal(12,2)
  differenceNotes   String?

  countDetail       Json?
  evidenceUrl       String?
  status            String  @default("BORRADOR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch      Branch      @relation(fields: [branchId],      references: [id])
  cashAccount CashAccount @relation(fields: [cashAccountId], references: [id])

  @@map("cash_counts")
}

// ══════════════════════════════════════════════════════════════
//  CUENTAS POR COBRAR (CxC)
// ══════════════════════════════════════════════════════════════

model Receivable {
  id             String   @id @default(cuid())
  companyId      String
  clientId       String
  cutLineId      String?
  rubricId       String?
  date           DateTime @db.Date
  dueDate        DateTime? @db.Date
  currency       String   @default("MXN")
  originalAmount Decimal  @db.Decimal(12,2)
  paidAmount     Decimal  @default(0) @db.Decimal(12,2)
  balance        Decimal  @db.Decimal(12,2)
  status         String   @default("PENDIENTE")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company  Company            @relation(fields: [companyId], references: [id])
  client   Client             @relation(fields: [clientId],  references: [id])
  payments ReceivablePayment[]

  @@map("receivables")
}

model ReceivablePayment {
  id            String   @id @default(cuid())
  receivableId  String
  cashAccountId String?
  date          DateTime @db.Date
  amount        Decimal  @db.Decimal(12,2)
  currency      String   @default("MXN")
  exchangeRate  Decimal  @default(1) @db.Decimal(10,4)
  paymentMethod String
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())

  receivable Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)

  @@map("receivable_payments")
}

// ══════════════════════════════════════════════════════════════
//  CUENTAS POR PAGAR (CxP)
// ══════════════════════════════════════════════════════════════

model Payable {
  id             String   @id @default(cuid())
  companyId      String
  supplierId     String?
  rubricId       String?
  concept        String
  date           DateTime @db.Date
  dueDate        DateTime? @db.Date
  currency       String   @default("MXN")
  originalAmount Decimal  @db.Decimal(12,2)
  paidAmount     Decimal  @default(0) @db.Decimal(12,2)
  balance        Decimal  @db.Decimal(12,2)
  status         String   @default("PENDIENTE")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company  Company         @relation(fields: [companyId],  references: [id])
  supplier Supplier?       @relation(fields: [supplierId], references: [id])
  payments PayablePayment[]

  @@map("payables")
}

model PayablePayment {
  id            String   @id @default(cuid())
  payableId     String
  cashAccountId String?
  date          DateTime @db.Date
  amount        Decimal  @db.Decimal(12,2)
  currency      String   @default("MXN")
  exchangeRate  Decimal  @default(1) @db.Decimal(10,4)
  paymentMethod String
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())

  payable Payable @relation(fields: [payableId], references: [id], onDelete: Cascade)

  @@map("payable_payments")
}

// ══════════════════════════════════════════════════════════════
//  GASTOS Y COMPRAS
// ══════════════════════════════════════════════════════════════

model Expense {
  id            String   @id @default(cuid())
  companyId     String
  supplierId    String?
  rubricId      String?
  cashAccountId String?
  userId        String

  date          DateTime @db.Date
  concept       String
  description   String?
  subtotal      Decimal  @db.Decimal(12,2)
  tax           Decimal  @default(0) @db.Decimal(12,2)
  total         Decimal  @db.Decimal(12,2)
  currency      String   @default("MXN")
  exchangeRate  Decimal  @default(1) @db.Decimal(10,4)
  totalMxn      Decimal  @db.Decimal(12,2)

  paymentStatus String   @default("PAGADO")
  paymentMethod String?

  invoiceRef    String?
  isExternal    Boolean  @default(false)
  externalNotes String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company          @relation(fields: [companyId],    references: [id])
  supplier    Supplier?        @relation(fields: [supplierId],   references: [id])
  rubric      FinancialRubric? @relation(fields: [rubricId],     references: [id])
  cashAccount CashAccount?     @relation(fields: [cashAccountId],references: [id])
  user        User             @relation(fields: [userId],       references: [id])
  documents   DocumentUpload[]

  @@map("expenses")
}

model Purchase {
  id            String   @id @default(cuid())
  companyId     String
  supplierId    String?
  rubricId      String?
  userId        String

  date          DateTime @db.Date
  concept       String
  total         Decimal  @db.Decimal(12,2)
  currency      String   @default("MXN")
  exchangeRate  Decimal  @default(1) @db.Decimal(10,4)
  totalMxn      Decimal  @db.Decimal(12,2)

  paymentStatus String   @default("PAGADO")
  affectsInventory Boolean @default(false)
  invoiceRef    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company          @relation(fields: [companyId],  references: [id])
  supplier Supplier?        @relation(fields: [supplierId], references: [id])
  rubric   FinancialRubric? @relation(fields: [rubricId],   references: [id])
  user     User             @relation(fields: [userId],     references: [id])
  items    PurchaseItem[]

  @@map("purchases")
}

model PurchaseItem {
  id          String  @id @default(cuid())
  purchaseId  String
  description String
  quantity    Decimal @db.Decimal(10,3)
  unit        String?
  unitCost    Decimal @db.Decimal(12,2)
  total       Decimal @db.Decimal(12,2)
  productId   String?

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@map("purchase_items")
}

// ══════════════════════════════════════════════════════════════
//  BANDEJA DOCUMENTAL
// ══════════════════════════════════════════════════════════════

model DocumentUpload {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  expenseId   String?

  type        String
  fileUrl     String
  fileName    String
  mimeType    String

  rawText     String?  @db.Text
  extractedJson Json?
  validatedJson Json?

  validatedById String?
  validatedAt   DateTime?

  originRecordId String?

  status      String   @default("CARGADO")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company  @relation(fields: [companyId], references: [id])
  user    User     @relation(fields: [userId],    references: [id])
  expense Expense? @relation(fields: [expenseId], references: [id])

  @@map("document_uploads")
}

// ══════════════════════════════════════════════════════════════
//  CIERRES MENSUALES
// ══════════════════════════════════════════════════════════════

model PeriodClosure {
  id        String   @id @default(cuid())
  companyId String
  period    String
  status    String   @default("ABIERTO")
  closedAt  DateTime?
  closedById String?

  incomeStatement Json?
  cashFlowSummary Json?
  balanceSummary  Json?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, period])
  @@map("period_closures")
}

// ══════════════════════════════════════════════════════════════
//  AUDITORÍA
// ══════════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  companyId  String?
  action     String
  entity     String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ══════════════════════════════════════════════════════════════
//  MÓDULO MACHETE — PRODUCCIÓN E INVENTARIO
// ══════════════════════════════════════════════════════════════

model Product {
  id           String  @id @default(cuid())
  companyId    String
  sku          String
  name         String
  meatType     String
  flavor       String
  presentation String
  gramsWeight  Int?
  isActive     Boolean @default(true)

  priceMostrador Decimal? @db.Decimal(10,2)
  priceMayoreo   Decimal? @db.Decimal(10,2)
  priceOnline    Decimal? @db.Decimal(10,2)
  priceML        Decimal? @db.Decimal(10,2)

  company       Company         @relation(fields: [companyId], references: [id])
  currentStock  ProductStock?
  saleLines     SaleLine[]
  lineasOC      LineaOC[]
  lotesEmpaque  LoteEmpaque[]

  @@unique([companyId, sku])
  @@map("products")
}

model ProductStock {
  id        String  @id @default(cuid())
  productId String  @unique
  stock     Decimal @default(0) @db.Decimal(10,2)
  minStock  Decimal @default(5) @db.Decimal(10,2)
  maxStock  Decimal @default(0) @db.Decimal(10,2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_stocks")
}

model Recipe {
  id              String   @id @default(cuid())
  companyId       String
  key             String
  theoreticalYield Decimal @db.Decimal(5,4)
  versionNumber   Int      @default(1)
  isActive        Boolean  @default(true)
  changedById     String?
  changeNote      String?
  createdAt       DateTime @default(now())

  company     Company          @relation(fields: [companyId], references: [id])
  ingredients RecipeIngredient[]
  batches     ProductionBatch[]

  @@unique([companyId, key, versionNumber])
  @@map("recipes")
}

model RecipeIngredient {
  id             String  @id @default(cuid())
  recipeId       String
  inputName      String
  quantityPer100g Decimal @db.Decimal(8,4)
  unit           String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_ingredients")
}

model ProductionBatch {
  id           String   @id @default(cuid())
  companyId    String
  recipeId     String
  recipeKey    String
  startDate    DateTime @db.Date
  endDate      DateTime? @db.Date
  status       String   @default("MARINANDO")

  kgInput      Decimal  @db.Decimal(10,3)
  kgOutput     Decimal? @db.Decimal(10,3)
  kgWaste      Decimal? @db.Decimal(10,3)
  realYield    Decimal? @db.Decimal(5,4)
  yieldOk      Boolean?

  inputsUsed   Json?
  distribution Json?

  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
