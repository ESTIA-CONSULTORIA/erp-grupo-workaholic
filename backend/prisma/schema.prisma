  delegateApproverId  String?   // sustituto si está ausente
  status              String    @default("PENDIENTE")
  // PENDIENTE | APROBADO | RECHAZADO | DELEGADO | VENCIDO
  comment             String?
  actedAt             DateTime?
  dueAt               DateTime?
  createdAt           DateTime  @default(now())
  request             ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  @@map("approval_steps")
}

