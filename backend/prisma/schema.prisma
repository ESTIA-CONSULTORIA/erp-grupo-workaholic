// ─────────────────────────────────────────────────────────────
//  PRISMA SCHEMA — ERP GRUPO WORKAHOLIC
//  DB: PostgreSQL (Supabase)
//  Principio: lógica por IDs/metadatos, nunca por títulos
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ══════════════════════════════════════════════════════════════
//  AUTENTICACIÓN Y USUARIOS
// ══════════════════════════════════════════════════════════════

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyRoles    UserCompanyRole[]
  branchRoles     UserBranchRole[]
  cutsCreated     Cut[]             @relation("CutCreatedBy")
  cutsApproved    Cut[]             @relation("CutApprovedBy")
  expenses        Expense[]
  purchases       Purchase[]
  documentUploads DocumentUpload[]
  auditLogs       AuditLog[]
  documents       Document[]
  pin             String?
  cortesCajero    CorteCaja[] @relation("CorteCajaCajero")
  cortesValidador CorteCaja[] @relation("CorteCajaValidador")
  employee        Employee?   @relation("UserEmployee")
  @@map("users")
}

model Role {
  id          String @id @default(cuid())
  code        String @unique
  // admin | gerente | contador | capturista
  name        String
  description String

  permissions  RolePermission[]
  companyRoles UserCompanyRole[]
  branchRoles  UserBranchRole[]

  @@map("roles")
}

// ══════════════════════════════════════════════════════════════
//  PERMISOS LEGACY
// ══════════════════════════════════════════════════════════════

model Permission {
  id   String @id @default(cuid())
  code String @unique
  name String

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId],       references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ══════════════════════════════════════════════════════════════
//  NUEVO SISTEMA DE PERMISOS POR MÓDULO Y ACCIÓN
// ══════════════════════════════════════════════════════════════

model RoleModulePermission {
  id          String  @id @default(cuid())
  roleCode    String
  module      String
  action      String
  allowed     Boolean @default(true)
  companyId   String?
  createdAt   DateTime @default(now())

  @@unique([roleCode, module, action, companyId])
  @@map("role_module_permissions")
}

// Usuario puede tener rol en múltiples empresas
model UserCompanyRole {
  id        String  @id @default(cuid())
  userId    String
  companyId String
  roleId    String
  user      User    @relation(fields: [userId],    references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role    @relation(fields: [roleId],    references: [id])

  @@unique([userId, companyId])
  @@map("user_company_roles")
}

// Capturistas asignados a sucursales específicas
model UserBranchRole {
  id       String @id @default(cuid())
  userId   String
  branchId String
  roleId   String
  user     User   @relation(fields: [userId],   references: [id], onDelete: Cascade)
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  role     Role   @relation(fields: [roleId],   references: [id])

  @@unique([userId, branchId])
  @@map("user_branch_roles")
}

// ══════════════════════════════════════════════════════════════
//  EMPRESAS Y SUCURSALES
// ══════════════════════════════════════════════════════════════

model Company {
  id          String  @id @default(cuid())
  code        String  @unique
  // machete | workaholic | palestra | lonche
  name        String
  color       String  @default("#3b82f6")
  logoUrl     String?
  hasAB       Boolean @default(true)  // tiene A&B
  hasProduction Boolean @default(false) // tiene producción (Machete)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branches         Branch[]
  userRoles        UserCompanyRole[]
  financialSchema  FinancialSchema?
  cashAccounts     CashAccount[]
  clients          Client[]
  suppliers        Supplier[]
  cuts             Cut[]
  expenses         Expense[]
  purchases        Purchase[]
  receivables      Receivable[]
  payables         Payable[]
  flowMovements    FlowMovement[]
  periodClosures   PeriodClosure[]
  documentUploads  DocumentUpload[]
  // Machete específico
  products         Product[]
  recipes          Recipe[]
  productionBatches ProductionBatch[]
  cxcs             CxC[]
  documents        Document[]
  employees        Employee[]
  hrConfig         CompanyHRConfig?
  payrollPeriods   PayrollPeriod[]
  insumos          Insumo[]
  ordenesCompra    OrdenCompra[]
  cortesCaja       CorteCaja[]
  lotesProduccion  LoteProduccion[]
  transfersFrom    IntercompanyTransfer[] @relation("TransferFrom")
  transfersTo      IntercompanyTransfer[] @relation("TransferTo")

  // ──────────────────── PALESTRA Y NUEVOS MÓDULOS ────────────────────
  serviceCatalog         ServiceCatalog[]
  membershipTypes        MembershipType[]
  memberships            Membership[]
  coachCommissions       CoachCommission[]
  softRestaurantImports  SoftRestaurantImport[]
  palestraProducts       PalestraProduct[]
  approvalRequests       ApprovalRequest[]
  notifications          Notification[]
  hrIncidents            HrIncident[]
  disabilities           Disability[]
  terminations           EmployeeTermination[]
  legalDocuments         LegalDocument[]
  payrollReceipts        PayrollReceipt[]
  workaSpaces            WorkaholicSpace[]
  workaMemTypes          WorkaholicMembershipType[]
  workaMemberships       WorkaholicMembership[]
  workaReservations      WorkaholicReservation[]
  workaPayments          WorkaholicPayment[]
  loncheProducts         LoncheProduct[]
  loncheTurnos           LoncheTurno[]
  loncheSales            LoncheSale[]
  loncheStudents         LoncheStudent[]
  loncheRecharges        LoncheRecharge[]
  loncheTransactions     LoncheTransaction[]

  @@map("companies")
}

model Branch {
  id        String  @id @default(cuid())
  companyId String
  code      String
  // vizcaya | colegio | xochimilco | compuertas (Lonche)
  // unica (resto de empresas)
  name      String
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userRoles   UserBranchRole[]
  cuts        Cut[]
  cashCounts  CashCount[]
  flowMovements FlowMovement[]
  employees   Employee[]

  @@unique([companyId, code])
  @@map("branches")
}

// ══════════════════════════════════════════════════════════════
//  ESQUEMA FINANCIERO POR EMPRESA (configurable)
// ══════════════════════════════════════════════════════════════

model FinancialSchema {
  id        String  @id @default(cuid())
  companyId String  @unique
  name      String  // "Esquema Palestra 2026"
  version   Int     @default(1)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sections FinancialSection[]

  @@map("financial_schemas")
}

model FinancialSection {
  id               String  @id @default(cuid())
  schemaId         String
  code             String
  // INGRESOS | COSTO_VENTA | GASTOS_GENERALES |
  // OBLIGACIONES | INVERSIONES | OPERACIONES_EXTERNAS | COMPROBACION
  name             String  // título visible editable
  order            Int
  isVisible        Boolean @default(true)
  affectsResult    Boolean @default(true)
  // false para OPERACIONES_EXTERNAS (se muestra pero no afecta operativo)

  schema FinancialSchema  @relation(fields: [schemaId], references: [id], onDelete: Cascade)
  groups FinancialGroup[]

  @@unique([schemaId, code])
  @@map("financial_sections")
}

model FinancialGroup {
  id        String  @id @default(cuid())
  sectionId String
  code      String
  name      String  // título visible editable
  order     Int
  isSummary Boolean @default(false)
  // true = muestra subtotal del grupo

  section FinancialSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  rubrics FinancialRubric[]

  @@unique([sectionId, code])
  @@map("financial_groups")
}

model FinancialRubric {
  id      String @id @default(cuid())
  groupId String
  code    String
  name    String  // título visible editable (ej: "Ingreso por membresías")
  order   Int

  // ── Atributos funcionales (lógica por metadata, no por nombre) ──
  rubricType        String
  // INGRESO | COSTO | GASTO | OBLIGACION | INVERSION |
  // TRASPASO | OPERACION_EXTERNA | CORTESIA | DESCUENTO

  // Qué acepta este rubro en captura
  allowsContado     Boolean @default(false)
  allowsCxC         Boolean @default(false)
  allowsDiscount    Boolean @default(false)
  allowsCourtesy    Boolean @default(false)
  requiresClient    Boolean @default(false)
  requiresSupplier  Boolean @default(false)
  requiresBank      Boolean @default(false)
  requiresTerminal  Boolean @default(false)

  // Qué afecta este rubro en reportes
  affectsGrossSale  Boolean @default(false)
  affectsNetSale    Boolean @default(false)
  affectsFlow       Boolean @default(false)
  affectsCxC        Boolean @default(false)
  affectsCxP        Boolean @default(false)
  affectsCost       Boolean @default(false)
  affectsExpense    Boolean @default(false)
  affectsResult     Boolean @default(true)
  affectsExternalOp Boolean @default(false)

  // Visibilidad en reportes
  showInSummary     Boolean @default(true)
  showInStatement   Boolean @default(true)
  showInDashboard   Boolean @default(true)

  isActive Boolean @default(true)

  group    FinancialGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  cutLines CutLine[]
  expenses Expense[]
  purchases Purchase[]

  @@unique([groupId, code])
  @@map("financial_rubrics")
}

// ══════════════════════════════════════════════════════════════
//  CATÁLOGOS MAESTROS
// ══════════════════════════════════════════════════════════════

model Client {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  email         String?
  phone         String?
  creditLimit   Decimal  @default(0) @db.Decimal(12,2)
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  rfc           String?
  address       String?
  creditDays    Int      @default(30)

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cutLines    CutLine[]
  receivables Receivable[]
  cxcs        CxC[]
  ordenesCompra OrdenCompra[]
  sales       Sale[]

  @@map("clients")
}

model Supplier {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses  Expense[]
  purchases Purchase[]
  payables  Payable[]

  @@map("suppliers")
}

model CashAccount {
  id        String  @id @default(cuid())
  companyId String
  code      String
  // efectivo_mxn | efectivo_usd | banregio_mxn | banregio_usd |
  // mercado_pago | stripe | caja_chica
  name      String
  type      String
  // EFECTIVO | BANCO | PLATAFORMA | CAJA_CHICA
  currency  String  @default("MXN")
  // MXN | USD
  bankName  String?
  accountNumber String?
  isActive  Boolean @default(true)

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cutLines      CutLine[]
  flowMovements FlowMovement[]
  cashCounts    CashCount[]
  expenses      Expense[]
  cxcPayments   CxCPayment[]

  @@unique([companyId, code])
  @@map("cash_accounts")
}

// ══════════════════════════════════════════════════════════════
//  CORTES
// ══════════════════════════════════════════════════════════════

model Cut {
  id           String   @id @default(cuid())
  companyId    String
  branchId     String
  folio        String
  date         DateTime @db.Date
  shift        String?  // MATUTINO | VESPERTINO | NOCTURNO
  status       String   @default("BORRADOR")
  // BORRADOR | ENVIADO | APROBADO | RECHAZADO
  notes        String?
  createdById  String
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company   @relation(fields: [companyId], references: [id])
  branch     Branch    @relation(fields: [branchId],  references: [id])
  createdBy  User      @relation("CutCreatedBy",  fields: [createdById],  references: [id])
  approvedBy User?     @relation("CutApprovedBy", fields: [approvedById], references: [id])
  lines      CutLine[]

  @@unique([companyId, folio])
  @@map("cuts")
}

model CutLine {
  id            String  @id @default(cuid())
  cutId         String
  rubricId      String
  clientId      String?
  cashAccountId String?

  paymentType   String
  // CONTADO | CXC
  currency      String  @default("MXN")
  // MXN | USD
  exchangeRate  Decimal @default(1) @db.Decimal(10,4)

  grossAmount   Decimal @db.Decimal(12,2)
  discount      Decimal @default(0) @db.Decimal(12,2)
  courtesy      Decimal @default(0) @db.Decimal(12,2)
  netAmount     Decimal @db.Decimal(12,2)
  // netAmount = grossAmount - discount - courtesy

  reference     String?
  notes         String?

  cut         Cut          @relation(fields: [cutId],         references: [id], onDelete: Cascade)
  rubric      FinancialRubric @relation(fields: [rubricId],  references: [id])
  client      Client?      @relation(fields: [clientId],     references: [id])
  cashAccount CashAccount? @relation(fields: [cashAccountId],references: [id])

  @@map("cut_lines")
}

// ══════════════════════════════════════════════════════════════
//  FLUJO DE EFECTIVO Y ARQUEOS
// ══════════════════════════════════════════════════════════════

model FlowMovement {
  id            String   @id @default(cuid())
  companyId     String
  branchId      String
  cashAccountId String
  date          DateTime @db.Date
  type          String
  // ENTRADA | SALIDA | TRASPASO_ORIGEN | TRASPASO_DESTINO
  originType    String
  // CORTE | GASTO | COMPRA | ABONO_CXC | PAGO_CXP | TRASPASO | AJUSTE
  originId      String?
  rubricId      String?
  amount        Decimal  @db.Decimal(12,2)
  currency      String   @default("MXN")
  exchangeRate  Decimal  @default(1) @db.Decimal(10,4)
  amountMxn     Decimal  @db.Decimal(12,2)
  // monto convertido a MXN
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())

  company     Company     @relation(fields: [companyId],     references: [id])
  branch      Branch      @relation(fields: [branchId],      references: [id])
  cashAccount CashAccount @relation(fields: [cashAccountId], references: [id])

  @@map("flow_movements")
}

model CashCount {
  id            String   @id @default(cuid())
  companyId     String
  branchId      String
  cashAccountId String
  date          DateTime @db.Date
  periodId      String?

  openingBalance  Decimal @db.Decimal(12,2)
  inflows         Decimal @db.Decimal(12,2)
  outflows        Decimal @db.Decimal(12,2)
  theoreticalBalance Decimal @db.Decimal(12,2)
  // openingBalance + inflows - outflows
  physicalCount   Decimal @db.Decimal(12,2)
  difference      Decimal @db.Decimal(12,2)
  // physicalCount - theoreticalBalance
  differenceNotes String?

  // Detalle del conteo físico (JSON)
  countDetail     Json?
  // { billetes: {1000:3, 500:10...}, monedas: {10:5...}, usd: {100:2...} }

  evidenceUrl     String?
  status          String  @default("BORRADOR")
  // BORRADOR | CERRADO

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch      Branch      @relation(fields: [branchId],      references: [id])
  cashAccount CashAccount @relation(fields: [cashAccountId], references: [id])

  @@map("cash_counts")
}

// ══════════════════════════════════════════════════════════════
//  CUENTAS POR COBRAR (CxC)
// ══════════════════════════════════════════════════════════════

model Receivable {
  id             String   @id @default(cuid())
  companyId      String
  clientId       String
  cutLineId      String?  // origen de la CxC
  rubricId       String?
  date           DateTime @db.Date
  dueDate        DateTime? @db.Date
  currency       String   @default("MXN")
  originalAmount Decimal  @db.Decimal(12,2)
  paidAmount     Decimal  @default(0) @db.Decimal(12,2)
  balance        Decimal  @db.Decimal(12,2)
  // balance = originalAmount - paidAmount
  status         String   @default("PENDIENTE")
  // PENDIENTE | PARCIAL | PAGADO | VENCIDO
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company  Company            @relation(fields: [companyId], references: [id])
  client   Client             @relation(fields: [clientId],  references: [id])
  payments ReceivablePayment[]

  @@map("receivables")
}

model ReceivablePayment {
  id            String   @id @default(cuid())
  receivableId  String
  cashAccountId String?
  date          DateTime @db.Date
  amount        Decimal  @db.Decimal(12,2)
  currency      String   @default("MXN")
  exchangeRate  Decimal  @default(1) @db.Decimal(10,4)
  paymentMethod String
  // EFECTIVO_MXN | EFECTIVO_USD | TRANSFERENCIA | TARJETA
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())

  receivable Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)

  @@map("receivable_payments")
}

// ══════════════════════════════════════════════════════════════
//  CUENTAS POR PAGAR (CxP)
// ══════════════════════════════════════════════════════════════

model Payable {
  id             String   @id @default(cuid())
  companyId      String
  supplierId     String?
  rubricId       String?
  concept        String
  date           DateTime @db.Date
  dueDate        DateTime? @db.Date
  currency       String   @default("MXN")
  originalAmount Decimal  @db.Decimal(12,2)
  paidAmount     Decimal  @default(0) @db.Decimal(12,2)
  balance        Decimal  @db.Decimal(12,2)
  status         String   @default("PENDIENTE")
  // PENDIENTE | PARCIAL | PAGADO
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company  Company         @relation(fields: [companyId],  references: [id])
  supplier Supplier?       @relation(fields: [supplierId], references: [id])
  payments PayablePayment[]

  @@map("payables")
}

model PayablePayment {
  id            String   @id @default(cuid())
  payableId     String
  cashAccountId String?
  date          DateTime @db.Date
  amount        Decimal  @db.Decimal(12,2)
  currency      String   @default("MXN")
  exchangeRate  Decimal  @default(1) @db.Decimal(10,4)
  paymentMethod String
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())

  payable Payable @relation(fields: [payableId], references: [id], onDelete: Cascade)

  @@map("payable_payments")
}

// ══════════════════════════════════════════════════════════════
//  GASTOS Y COMPRAS
// ══════════════════════════════════════════════════════════════

model Expense {
  id            String   @id @default(cuid())
  companyId     String
  supplierId    String?
  rubricId      String?
  cashAccountId String?
  userId        String

  date          DateTime @db.Date
  concept       String
  description   String?
  subtotal      Decimal  @db.Decimal(12,2)
  tax           Decimal  @default(0) @db.Decimal(12,2)
  total         Decimal  @db.Decimal(12,2)
  currency      String   @default("MXN")
  exchangeRate  Decimal  @default(1) @db.Decimal(10,4)
  totalMxn      Decimal  @db.Decimal(12,2)

  paymentStatus String   @default("PAGADO")
  // PAGADO | PENDIENTE | MIXTO
  paymentMethod String?
  // EFECTIVO_MXN | EFECTIVO_USD | TRANSFERENCIA | TARJETA

  invoiceRef    String?  // número de factura
  isExternal    Boolean  @default(false)
  // true = operación externa al negocio (separada del resultado operativo)
  externalNotes String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company         @relation(fields: [companyId],    references: [id])
  supplier    Supplier?       @relation(fields: [supplierId],   references: [id])
  rubric      FinancialRubric? @relation(fields: [rubricId],    references: [id])
  cashAccount CashAccount?    @relation(fields: [cashAccountId],references: [id])
  user        User            @relation(fields: [userId],       references: [id])
  documents   DocumentUpload[]

  @@map("expenses")
}

model Purchase {
  id            String   @id @default(cuid())
  companyId     String
  supplierId    String?
  rubricId      String?
  userId        String

  date          DateTime @db.Date
  concept       String
  total         Decimal  @db.Decimal(12,2)
  currency      String   @default("MXN")
  exchangeRate  Decimal  @default(1) @db.Decimal(10,4)
  totalMxn      Decimal  @db.Decimal(12,2)

  paymentStatus String   @default("PAGADO")
  affectsInventory Boolean @default(false)
  invoiceRef    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company          @relation(fields: [companyId],  references: [id])
  supplier Supplier?        @relation(fields: [supplierId], references: [id])
  rubric   FinancialRubric? @relation(fields: [rubricId],   references: [id])
  user     User             @relation(fields: [userId],     references: [id])
  items    PurchaseItem[]

  @@map("purchases")
}

model PurchaseItem {
  id          String  @id @default(cuid())
  purchaseId  String
  description String
  quantity    Decimal @db.Decimal(10,3)
  unit        String?
  unitCost    Decimal @db.Decimal(12,2)
  total       Decimal @db.Decimal(12,2)
  productId   String?

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@map("purchase_items")
}

// ══════════════════════════════════════════════════════════════
//  BANDEJA DOCUMENTAL (tickets, facturas, cortes en foto)
// ══════════════════════════════════════════════════════════════

model DocumentUpload {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  expenseId   String?

  type        String
  // CORTE | COMPRA | GASTO | FACTURA | TICKET | RECIBO

  fileUrl     String
  fileName    String
  mimeType    String

  // OCR / Extracción IA
  rawText     String?  @db.Text
  extractedJson Json?
  // { proveedor, fecha, total, subtotal, iva, conceptos[] }
  validatedJson Json?
  // JSON revisado y editado por el usuario

  // Quién revisó
  validatedById String?
  validatedAt   DateTime?

  originRecordId String?
  // ID del gasto/compra/corte que se generó desde este documento

  status      String   @default("CARGADO")
  // CARGADO | PROCESANDO | PENDIENTE_VALIDACION |
  // VALIDADO | RECHAZADO | ARCHIVADO

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company  @relation(fields: [companyId], references: [id])
  user    User     @relation(fields: [userId],    references: [id])
  expense Expense? @relation(fields: [expenseId], references: [id])

  @@map("document_uploads")
}

// ══════════════════════════════════════════════════════════════
//  CIERRES MENSUALES
// ══════════════════════════════════════════════════════════════

model PeriodClosure {
  id        String   @id @default(cuid())
  companyId String
  period    String
  // "2026-03" — año-mes
  status    String   @default("ABIERTO")
  // ABIERTO | EN_CIERRE | CERRADO
  closedAt  DateTime?
  closedById String?

  // Snapshots del estado financiero al cierre
  incomeStatement Json?
  cashFlowSummary Json?
  balanceSummary  Json?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, period])
  @@map("period_closures")
}

// ══════════════════════════════════════════════════════════════
//  AUDITORÍA
// ══════════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  companyId  String?
  action     String
  // CREATE | UPDATE | DELETE | APPROVE | REJECT | LOGIN | CLOSE_PERIOD
  entity     String   // cuts | expenses | receivables | etc.
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ══════════════════════════════════════════════════════════════
//  MÓDULO MACHETE — PRODUCCIÓN E INVENTARIO
// ══════════════════════════════════════════════════════════════

model Product {
  id           String  @id @default(cuid())
  companyId    String
  sku          String
  // RES-NAT-100G | CER-CHI-500G etc.
  name         String
  meatType     String  // RES | CER
  flavor       String  // NAT | CHI | BBQ
  presentation String  // 100G | 250G | 500G | 1KG
  gramsWeight  Int?
  isActive     Boolean @default(true)

  // Precios por canal
  priceMostrador Decimal? @db.Decimal(10,2)
  priceMayoreo   Decimal? @db.Decimal(10,2)
  priceOnline    Decimal? @db.Decimal(10,2)
  priceML        Decimal? @db.Decimal(10,2)

  company       Company         @relation(fields: [companyId], references: [id])
  currentStock  ProductStock?
  saleLines     SaleLine[]
  lineasOC      LineaOC[]
  lotesEmpaque  LoteEmpaque[]

  @@unique([companyId, sku])
  @@map("products")
}

model ProductStock {
  id        String  @id @default(cuid())
  productId String  @unique
  stock     Decimal @default(0) @db.Decimal(10,2)
  minStock  Decimal @default(5) @db.Decimal(10,2)
  maxStock  Decimal @default(0) @db.Decimal(10,2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_stocks")
}

model Recipe {
  id              String   @id @default(cuid())
  companyId       String
  key             String
  // RES-NAT | RES-CHI | CER-BBQ etc.
  theoreticalYield Decimal @db.Decimal(5,4)
  // 0.38 = 38% rendimiento kg salida / kg entrada
  versionNumber   Int      @default(1)
  isActive        Boolean  @default(true)
  changedById     String?
  changeNote      String?
  createdAt       DateTime @default(now())

  company     Company          @relation(fields: [companyId], references: [id])
  ingredients RecipeIngredient[]
  batches     ProductionBatch[]

  @@unique([companyId, key, versionNumber])
  @@map("recipes")
}

model RecipeIngredient {
  id             String  @id @default(cuid())
  recipeId       String
  inputName      String  // CARNE_RES | SAL | CHILE_ROJO etc.
  quantityPer100g Decimal @db.Decimal(8,4)
  // cantidad de insumo por 100g de producto terminado
  unit           String  // kg | lt | pza

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_ingredients")
}

model ProductionBatch {
  id           String   @id @default(cuid())
  companyId    String
  recipeId     String
  recipeKey    String
  startDate    DateTime @db.Date
  endDate      DateTime? @db.Date
  status       String   @default("MARINANDO")
  // MARINANDO | SECANDO | TERMINADO

  kgInput      Decimal  @db.Decimal(10,3)
  kgOutput     Decimal? @db.Decimal(10,3)
  kgWaste      Decimal? @db.Decimal(10,3)
  realYield    Decimal? @db.Decimal(5,4)
  yieldOk      Boolean?

  inputsUsed   Json?
  // [{ inputName, quantity, unit }]
  distribution Json?
  // [{ sku, units }]

  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  recipe  Recipe  @relation(fields: [recipeId],  references: [id])

  @@map("production_batches")
}

model Sale {
  id            String   @id @default(cuid())
  companyId     String
  date          DateTime @db.Date
  channel       String   // MOSTRADOR | MAYOREO | ONLINE | ML
  clientName    String?
  subtotal      Decimal  @db.Decimal(12,2) @default(0) // antes de IVA
  tax           Decimal  @db.Decimal(12,2) @default(0) // IVA trasladado
  total         Decimal  @db.Decimal(12,2)              // subtotal + tax
  paymentMethod String
  cutId         String?
  notes         String?
  createdAt     DateTime @default(now())
  lines         SaleLine[]
  clientId      String?
  isCredit      Boolean  @default(false)
  client        Client?  @relation(fields: [clientId], references: [id])
  @@map("sales")
}

model SaleLine {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10,2)
  total     Decimal @db.Decimal(10,2)

  sale    Sale    @relation(fields: [saleId],    references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("sale_lines")
}

// ══════════════════════════════════════════════════════════════
//  CXC — CUENTAS POR COBRAR
// ══════════════════════════════════════════════════════════════
model CxC {
  id             String   @id @default(cuid())
  companyId      String
  clientId       String?
  date           DateTime
  dueDate        DateTime?
  concept        String
  originalAmount Decimal  @db.Decimal(12,2)
  paidAmount     Decimal  @db.Decimal(12,2) @default(0)
  balance        Decimal  @db.Decimal(12,2)
  currency       String   @default("MXN")
  status         String   @default("PENDIENTE")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company  Company       @relation(fields: [companyId], references: [id])
  client   Client?       @relation(fields: [clientId],  references: [id])
  payments CxCPayment[]
  @@map("cxc")
}

model CxCPayment {
  id            String   @id @default(cuid())
  cxcId         String
  amount        Decimal  @db.Decimal(12,2)
  currency      String   @default("MXN")
  paymentMethod String   @default("EFECTIVO_MXN")
  date          DateTime
  reference     String?
  cashAccountId String?
  createdAt     DateTime @default(now())
  cxc         CxC         @relation(fields: [cxcId], references: [id], onDelete: Cascade)
  cashAccount CashAccount? @relation(fields: [cashAccountId], references: [id])
  @@map("cxc_payments")
}

// ══════════════════════════════════════════════════════════════
//  DOCUMENTOS
// ══════════════════════════════════════════════════════════════
model Document {
  id            String   @id @default(cuid())
  companyId     String
  userId        String
  type          String   @default("TICKET")
  fileUrl       String?
  fileName      String?
  mimeType      String?
  status        String   @default("CARGADO")
  extractedJson Json?
  validatedJson Json?
  linkedId      String?  // ID del gasto o compra creado
  linkedType    String?  // 'GASTO' | 'COMPRA'
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId],    references: [id])
  @@map("documents")
}

// ══════════════════════════════════════════════════════════════
//  RH — RECURSOS HUMANOS
// ══════════════════════════════════════════════════════════════
model Employee {
  id             String   @id @default(cuid())
  companyId      String
  branchId       String?
  employeeNumber String
  firstName      String
  lastName       String
  secondLastName String?
  rfc            String?
  curp           String?
  nss            String?
  birthDate      DateTime?
  gender         String?
  phone          String?
  email          String?
  address        String?
  position       String
  department     String?
  startDate      DateTime
  endDate        DateTime?
  contractType   String   @default("INDEFINIDO")
  salaryType     String   @default("MENSUAL")
  grossSalary    Decimal  @db.Decimal(12,2) @default(0)
  dailySalary    Decimal  @db.Decimal(12,2) @default(0)
  bankAccount    String?
  bankName       String?
  repseNumber    String?
  repseExpiry    DateTime?
  // ── CONFIGURACIÓN DE NÓMINA ─────────────────────────────
  splitMode         String?  @default("TOTAL_TIMBRADO") // TOTAL_TIMBRADO | MIXTO | TOTAL_EFECTIVO
  montoFijoTimbrado Decimal? @db.Decimal(12,2) // monto fijo timbrado (si MIXTO)
  pctTimbrado       Decimal? @db.Decimal(5,2)  // % timbrado (si MIXTO y no hay monto fijo)
  status         String   @default("ACTIVO")
  userId         String?  @unique // vinculo con usuario del sistema
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company       Company            @relation(fields: [companyId], references: [id])
  branch        Branch?            @relation(fields: [branchId],  references: [id])
  user          User?              @relation("UserEmployee", fields: [userId], references: [id])
  documents     EmployeeDocument[]
  vacations     VacationRequest[]
  hrEvents      HREvent[]
  payrollLines      PayrollLine[]
  coachCommissions  CoachCommission[]
  hrIncidents       HrIncident[]
  disabilities      Disability[]
  terminations      EmployeeTermination[]
  legalDocuments    LegalDocument[]
  payrollReceipts   PayrollReceipt[]
  @@unique([companyId, employeeNumber])
  @@map("employees")
}

model EmployeeDocument {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  uploadedById String?
  type         String
  title        String
  fileUrl      String?
  fileName     String?
  mimeType     String?
  startDate    DateTime?
  endDate      DateTime?
  signedAt     DateTime?
  notes        String?
  status       String   @default("VIGENTE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@map("employee_documents")
}

model VacationRequest {
  id              String    @id @default(cuid())
  companyId       String
  employeeId      String
  type            String    @default("VACACIONES") // VACACIONES | PERMISO_CON_GOCE | PERMISO_SIN_GOCE | SUSPENSION
  startDate       DateTime
  endDate         DateTime
  days            Int
  businessDays    Int?      // días hábiles LFT
  primaVacacional Decimal?  @db.Decimal(10,2) // 25% sobre salario diario × días
  conGoce         Boolean   @default(true)     // afecta nómina si false
  // PENDIENTE | APROBADO_JEFE | APROBADO | RECHAZADO | CANCELADA |
  // PAGADA_SIN_GOZAR | GOZADA | PAGADA_Y_GOZADA
  status          String    @default("PENDIENTE")
  paymentType     String    @default("GOZAR") // GOZAR | PAGAR_SIN_GOZAR | AMBOS
  pagoRegistrado  Boolean   @default(false)   // ¿ya se incluyó en nómina?
  gozadaAt        DateTime?                   // cuando realmente tomó los días
  plazoGozar      DateTime?                   // límite para gozarlos (si PAGAR_SIN_GOZAR)
  montoTimbrado   Decimal?  @db.Decimal(12,2)
  montoEfectivo   Decimal?  @db.Decimal(12,2)
  montoPrima      Decimal?  @db.Decimal(12,2) // 25% prima vacacional
  requestedById   String?
  approvedByJefe  String?
  approvedByRH    String?
  approvedAt      DateTime?
  rejectedReason  String?
  notes           String?
  createdAt       DateTime  @default(now())
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@map("vacation_requests")
}

model HREvent {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  createdById  String?
  type         String
  date         DateTime
  description  String
  resolution   String?
  createdAt    DateTime @default(now())
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@map("hr_events")
}

model CompanyHRConfig {
  id          String  @id @default(cuid())
  companyId   String  @unique
  hasRepse    Boolean @default(false)
  payrollType String  @default("QUINCENAL")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company Company @relation(fields: [companyId], references: [id])
  @@map("company_hr_configs")
}

// ══════════════════════════════════════════════════════════════
//  NÓMINA
// ══════════════════════════════════════════════════════════════
model PayrollPeriod {
  id           String   @id @default(cuid())
  companyId    String
  type         String   @default("QUINCENAL")
  period       String
  periodEnd    String
  periodLabel  String
  status       String   @default("ABIERTO")
  totalGross   Decimal? @db.Decimal(12,2)
  totalNet     Decimal? @db.Decimal(12,2)
  totalIMSS    Decimal? @db.Decimal(12,2)
  totalISR     Decimal? @db.Decimal(12,2)
  exportedAt   DateTime?
  paidAt       DateTime?
  paidById     String?
  flowMovementId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company Company       @relation(fields: [companyId], references: [id])
  lines   PayrollLine[]
  @@map("payroll_periods")
}

model PayrollLine {
  id               String  @id @default(cuid())
  payrollPeriodId  String
  employeeId       String
  companyId        String
  baseSalary       Decimal @db.Decimal(12,2) @default(0)
  overtime         Decimal @db.Decimal(12,2) @default(0)
  bonus            Decimal @db.Decimal(12,2) @default(0)
  commission       Decimal @db.Decimal(12,2) @default(0)
  vacationPremium  Decimal @db.Decimal(12,2) @default(0)
  otherPerceptions Decimal @db.Decimal(12,2) @default(0)
  totalPerceptions Decimal @db.Decimal(12,2) @default(0)
  imssEmployee     Decimal @db.Decimal(12,2) @default(0)
  isrRetention     Decimal @db.Decimal(12,2) @default(0)
  infonavit        Decimal @db.Decimal(12,2) @default(0)
  loans            Decimal @db.Decimal(12,2) @default(0)
  otherDeductions  Decimal @db.Decimal(12,2) @default(0)
  totalDeductions  Decimal @db.Decimal(12,2) @default(0)
  netPay           Decimal @db.Decimal(12,2) @default(0)
  imssEmployer     Decimal @db.Decimal(12,2) @default(0)
  notes            String?
  // ── SPLIT TIMBRADO / EFECTIVO ────────────────────────────
  // El empleado solo ve la parte timbrada. Solo contador/admin ve el total.
  netTimbrado      Decimal @db.Decimal(12,2) @default(0) // neto SAT (visible al empleado)
  netEfectivo      Decimal @db.Decimal(12,2) @default(0) // complemento en efectivo (solo contador/admin)
  baseTimbrado     Decimal @db.Decimal(12,2) @default(0) // base para IMSS/ISR
  baseEfectivo     Decimal @db.Decimal(12,2) @default(0) // complemento sin deducciones
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  period   PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employeeId],      references: [id])
  @@unique([payrollPeriodId, employeeId])
  @@map("payroll_lines")
}

model Insumo {
  id        String  @id @default(cuid())
  companyId String
  sku       String
  name      String
  unit      String  @default("kg")
  costUnit  Decimal @db.Decimal(12,4) @default(0)
  group     String  @default("GENERAL")
  stock     Decimal @db.Decimal(12,4) @default(0)
  minStock  Decimal @db.Decimal(12,4) @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company Company @relation(fields: [companyId], references: [id])
  @@unique([companyId, sku])
  @@map("insumos")
}

model OrdenCompra {
  id          String   @id @default(cuid())
  companyId   String
  clientId    String
  numero      String
  fecha       DateTime
  montoTotal  Decimal  @db.Decimal(12,2)
  montoSurtido Decimal @db.Decimal(12,2) @default(0)
  saldo       Decimal  @db.Decimal(12,2)
  status            String   @default("PENDIENTE")
  fechaEntregaSol   DateTime? @db.Date
  fechaEntregaReal  DateTime? @db.Date
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company   Company        @relation(fields: [companyId], references: [id])
  client    Client         @relation(fields: [clientId],  references: [id])
  surtidos  SurtidoOC[]
  lineas    LineaOC[]
  @@unique([companyId, numero])
  @@map("ordenes_compra")
}

model SurtidoOC {
  id           String   @id @default(cuid())
  ordenCompraId String
  fecha        DateTime
  monto        Decimal  @db.Decimal(12,2)
  notes        String?
  createdAt    DateTime @default(now())
  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  @@map("surtidos_oc")
}

model LineaOC {
  id           String   @id @default(cuid())
  ordenCompraId String
  productId    String
  cantidad     Int
  cantidadSurtida Int   @default(0)
  precioUnitario Decimal @db.Decimal(12,2)
  total        Decimal  @db.Decimal(12,2)
  createdAt    DateTime @default(now())
  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId],     references: [id])
  @@map("lineas_oc")
}

model CorteCaja {
  id              String   @id @default(cuid())
  companyId       String
  branchId        String?
  cajeroId        String
  fecha           DateTime @db.Date
  status          String   @default("PENDIENTE")
  totalVentas     Decimal  @db.Decimal(12,2) @default(0)
  totalEfectivo   Decimal  @db.Decimal(12,2) @default(0)
  totalTarjeta    Decimal  @db.Decimal(12,2) @default(0)
  totalTransfer   Decimal  @db.Decimal(12,2) @default(0)
  totalCredito    Decimal  @db.Decimal(12,2) @default(0)
  efectivoContado Decimal  @db.Decimal(12,2) @default(0)
  efectivoReal    Decimal? @db.Decimal(12,2)
  diferencia      Decimal  @db.Decimal(12,2) @default(0)
  notasCajero     String?  @db.Text
  notasValidador  String?  @db.Text
  validadoPor     String?
  validadoAt      DateTime?
  detalleVentas   Json?
  desgloseDenominaciones Json?
  desgloseTerminales     Json?
  desgloseDelivery       Json?
  totalDelivery          Decimal  @db.Decimal(12,2) @default(0)
  totalTerminal          Decimal  @db.Decimal(12,2) @default(0)
  diferenciEfectivo      Decimal  @db.Decimal(12,2) @default(0)
  diferenciaTerminal     Decimal  @db.Decimal(12,2) @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company  Company @relation(fields: [companyId], references: [id])
  cajero   User    @relation("CorteCajaCajero",    fields: [cajeroId],    references: [id])
  validador User?  @relation("CorteCajaValidador", fields: [validadoPor], references: [id])
  @@map("cortes_caja")
}

model LoteProduccion {
  id          String   @id @default(cuid())
  companyId   String
  fecha       DateTime @db.Date
  tipo        String
  // MACHETE_RES | CHICALI_RES | CERDO | MACHACA
  status      String   @default("EN_PROCESO")
  // EN_PROCESO | EMPACADO | CERRADO
  kgEntrada   Decimal  @db.Decimal(10,3) @default(0)
  kgSalida    Decimal  @db.Decimal(10,3) @default(0)
  kgGrasa     Decimal  @db.Decimal(10,3) @default(0)
  kgMerma     Decimal  @db.Decimal(10,3) @default(0)
  rendimiento Decimal  @db.Decimal(5,2)  @default(0)
  // porcentaje calculado
  kgEscarchado Decimal @db.Decimal(10,3) @default(0)
  notas       String?
  creadoPor   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company   Company            @relation(fields: [companyId], references: [id])
  insumos   LoteInsumo[]
  empaques  LoteEmpaque[]
  @@map("lotes_produccion")
}

model LoteInsumo {
  id              String  @id @default(cuid())
  loteId          String
  insumoId        String?
  nombre          String
  cantidad        Decimal @db.Decimal(10,3)
  unidad          String  @default("kg")
  costoUnitario   Decimal @db.Decimal(12,4) @default(0)
  costoTotal      Decimal @db.Decimal(12,2) @default(0)
  createdAt       DateTime @default(now())
  lote   LoteProduccion @relation(fields: [loteId], references: [id], onDelete: Cascade)
  @@map("lote_insumos")
}

model LoteEmpaque {
  id         String  @id @default(cuid())
  loteId     String
  productId  String
  cantidad   Int
  costoUnit  Decimal @db.Decimal(12,4) @default(0)
  createdAt  DateTime @default(now())
  lote    LoteProduccion @relation(fields: [loteId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  @@map("lote_empaques")
}

model IntercompanyTransfer {
  id            String   @id @default(cuid())
  folio         String?  // ICT-0001
  fromCompanyId String
  toCompanyId   String
  amount        Decimal  @db.Decimal(12,2)
  currency      String   @default("MXN")
  concept       String
  date          DateTime @db.Date
  status        String   @default("PENDIENTE") // PENDIENTE | APROBADO | RECHAZADO
  requestedById String
  approvedById  String?
  approvedAt    DateTime?
  notes              String?
  fromCashAccountId  String?  // cuenta de donde sale el dinero
  toCashAccountId    String?  // cuenta donde entra el dinero
  rejectedReason     String?  // motivo de rechazo
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  fromCompany   Company  @relation("TransferFrom", fields: [fromCompanyId], references: [id])
  toCompany     Company  @relation("TransferTo",   fields: [toCompanyId],   references: [id])
  @@map("intercompany_transfers")
}

// ══════════════════════════════════════════════════════════════
//  PALESTRA — MEMBRESÍAS Y SERVICIOS
// ══════════════════════════════════════════════════════════════

model ServiceCatalog {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  type        String   @default("SERVICIO") // MEMBRESIA | SERVICIO | CLASE | CLINICA | RENTA | MANTENIMIENTO
  price       Decimal  @db.Decimal(12,2)
  duration    Int?     // minutos (para clases/rentas)
  isActive    Boolean  @default(true)
  coachable   Boolean  @default(false) // genera comisión de coach
  coachRate   Decimal? @db.Decimal(12,2) // monto fijo de comisión
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])
  @@map("service_catalog")
}

model MembershipType {
  id              String   @id @default(cuid())
  companyId       String
  name            String   // "Individual", "Familiar", "Corporativa"
  description     String?
  entryFee        Decimal  @db.Decimal(12,2) // costo de entrada (único)
  monthlyFee      Decimal  @db.Decimal(12,2) // mantenimiento mensual
  maxMembers      Int      @default(1)        // miembros por membresía
  graceDays       Int      @default(5)        // días de gracia antes de bloquear
