  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])
  @@map("service_catalog")
}

model MembershipType {
  id              String   @id @default(cuid())
  companyId       String
  name            String   // "Individual", "Familiar", "Corporativa"
  description     String?
  entryFee        Decimal  @db.Decimal(12,2) // costo de entrada (único)
  monthlyFee      Decimal  @db.Decimal(12,2) // mantenimiento mensual
  maxMembers      Int      @default(1)        // miembros por membresía
  graceDays       Int      @default(5)        // días de gracia antes de bloquear
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company  @relation(fields: [companyId], references: [id])
  memberships     Membership[]
  @@map("membership_types")
}

model Membership {
  id              String    @id @default(cuid())
  companyId       String
  membershipTypeId String
  folio           String    // PALS-0001
  status          String    @default("ACTIVA") // ACTIVA | MOROSA | SUSPENDIDA | CANCELADA
  holderName      String    // nombre del titular
  holderEmail     String?
  holderPhone     String?
  holderRfc       String?
  groupName       String?   // nombre del grupo si aplica
  startDate       DateTime  @db.Date
  entryPaid       Boolean   @default(false)
  entryPaidAt     DateTime?
  lastPaymentDate DateTime? @db.Date
  nextDueDate     DateTime? @db.Date
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company         @relation(fields: [companyId], references: [id])
  membershipType  MembershipType  @relation(fields: [membershipTypeId], references: [id])
