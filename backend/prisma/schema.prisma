  grade         String?  // "3B", "5A"
  tutorName     String?
  tutorEmail    String?
  tutorPhone    String?
  balance       Decimal  @db.Decimal(12,2) @default(0) // saldo prepago
  cashback      Decimal  @db.Decimal(12,2) @default(0) // saldo cashback acumulado
  dailyLimit    Decimal? @db.Decimal(10,2)              // tope diario del tutor
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id])
  recharges     LoncheRecharge[]
  transactions  LoncheTransaction[]
  @@unique([companyId, code])
  @@map("lonche_students")
}

model LoncheRecharge {
  id            String   @id @default(cuid())
  companyId     String
  studentId     String
  amount        Decimal  @db.Decimal(12,2)
  paymentMethod String   @default("EFECTIVO") // EFECTIVO | TRANSFERENCIA | EN_LINEA
  reference     String?
  rechargedById String?  // userId de cajero o null si fue en línea
  createdAt     DateTime @default(now())
  company       Company       @relation(fields: [companyId], references: [id])
  student       LoncheStudent @relation(fields: [studentId], references: [id])
  @@map("lonche_recharges")
}

model LoncheTransaction {
  id          String   @id @default(cuid())
  companyId   String
  studentId   String
  type        String   // RECARGA | COMPRA | CASHBACK | AJUSTE
  amount      Decimal  @db.Decimal(12,2) // positivo = entrada, negativo = salida
  balance     Decimal  @db.Decimal(12,2) // saldo después
  saleId      String?
  notes       String?
  createdAt   DateTime @default(now())
  company     Company       @relation(fields: [companyId], references: [id])
  student     LoncheStudent @relation(fields: [studentId], references: [id])
  @@map("lonche_transactions")
}

