  companyId   String
  name        String
  description String?
  type        String   @default("SERVICIO") // MEMBRESIA | SERVICIO | CLASE | CLINICA | RENTA | MANTENIMIENTO
  price       Decimal  @db.Decimal(12,2)
  duration    Int?     // minutos (para clases/rentas)
  isActive    Boolean  @default(true)
