// ══════════════════════════════════════════════════════════════

model ApprovalRequest {
  id               String    @id @default(cuid())
  companyId        String
  type             String    // VACACION | PERMISO | INCAPACIDAD | BAJA | FINIQUITO | ARQUEO | GASTO
  entityId         String?   // ID del registro relacionado
  entityType       String?   // vacation_request | hr_incident | termination | etc.
  requestedById    String    // userId
  requestedByRole  String
  status           String    @default("PENDIENTE")
  // PENDIENTE | EN_REVISION | APROBADO | RECHAZADO | CANCELADO | VENCIDO
  currentStep      Int       @default(1)
  priority         String    @default("NORMAL") // BAJA | NORMAL | ALTA | URGENTE
  dueAt            DateTime?
  metadata         Json?     // snapshot del dato al momento de solicitar
